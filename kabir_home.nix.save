qq   {config, pkgs, ...}:
{
	home.username = "kabir";
	home.homeDirectory = "/home/kabir";

	programs = {
		bash = {
			enable = true;
  			initExtra = ''
				  # export PATH=$PATH:/usr/bin 
			    # echo ґ░е│ рдЧрдВ рдЧрдгрдкрддрдпреЗ рдирдордГред
          
          fastfetch

          source ~/git-prompt.sh
          PROMPT_COMMAND='PS1_CMD1=$(__git_ps1 " (%s)")'; PS1='\n\[\e[2m\]тХнтФАтФА \[\e[1;3m\]яАЗ\[\e[0m\] \[\e[1;2;3m\]\u\[\e[0m\]  \n\[\e[2m\]тФЬтФАтФА \[\e[1;3m\]юпЖ\[\e[0m\] \[\e[1;2;3m\]\H\n\[\e[0;2m\]тФЬтФАтФА \[\e[1;3m\]яУФ\[\e[0m\] \[\e[1;2;3m\]\w\[\e[38;5;230m\]$PS1_CMD1\n\[\e[0;2m\]тФВ\nтФВ\n\[\e[0m\]\[\e[1;2m\]тХ░тФАтФА ґ░е│ \[\e[0m\]'
      '';
			shellAliases = {
        la="ls -al";
        
        crclone="sh ~/Documents/rclone\\ sync.sh";
				
				editconf="nvim ~/nix-flake/configuration.nix";
				editflake="nvim ~/nix-flake/flake.nix";

				nrs="sudo nixos-rebuild switch --impure --flake ~/nix-flake/";
				nfu="nix flake update --flake ~/nix-flake/ && nrs";

				smcs="cd ~/Documents/Sync\\ Sewer; sh start.sh";

			};
		};
	
    fastfetch = {
      enable = true;
      settings = {
        logo = {
          source = "nixos";
          padding = {
            top = 1;
            right = 4;
            left = 2;
          };
        };

        display = {
          size = {
            binaryPrefix = "si";
          };
          color = "blue";
          separator = " яЕ╕  ";
        };
        modules = [
          "break"
          "break"
          "break"
          "break"

          {
              type = "host";
              key = "PC";
              keyColor = "blue";
          }

          {
              type = "cpu";
              key = "ґ░╗а ";
              keyColor = "blue";
          }

          {
              type = "gpu";
              key = "ґ░Н╣ ";
              keyColor = "blue";
          }

          {
              type = "memory";
              key = "ґ░Сн ";
              keyColor = "blue";
          }

          "break"

          {
              type = "os";
              key = "OS";
              keyColor = "cyan";
          }

          {
              type = "kernel";
              key = "ґ░М╜ ";
              keyColor = "cyan";
          }

          {
              type = "packages";
              key = "ґ░ПЧ ";
              keyColor = "cyan";
          }

          {
              type = "shell";
              key = "ґ░Ю╖ ";
              keyColor = "cyan";
          }

          "break"

          {
              type = "de";
              key = "DE";
              keyColor = "blue";
          }

          {
              type = "wm";
              key = "ґ▒Вм ";
              keyColor = "blue";
          }

          {
              type = "wmtheme";
              key = "ґ░Йж ";
              keyColor = "blue";
          }

          {
              type = "terminal";
              key = "ґ░ЖН ";
              keyColor = "blue";
          }
          "break"
        ];
      };
    };
  };

	home.stateVersion = "25.11";
}
